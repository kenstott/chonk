# =============================================================================
# chonk — Environment Variables Reference
# =============================================================================
# Copy this file to .env (never commit .env) and fill in your values.
# The .env file is loaded automatically by:
#   • scripts/gmail_auth.py  (via python-dotenv)
#   • aipa_test_mcp_server/server.py  (built-in loader, no extra dependency)
# All other entry points read variables directly from the shell environment.
#
# Required variables are marked  [REQUIRED].
# Optional variables show their default in parentheses.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------

# Together.ai — used by mcp_chonk_server.py, aipa_test_mcp_server/server.py,
#               and demo/graphrag_bench.py  [REQUIRED for ask/generate features]
TOGETHER_API_KEY=

# OpenAI — used by demo/graphrag_bench.py, demo/compare_runs.py,
#           and chonk/ingest.py (SVO graph extraction)  [REQUIRED for OpenAI features]
OPENAI_API_KEY=

# Anthropic — used by demo/graphrag_bench.py  [REQUIRED for Anthropic/Claude features]
ANTHROPIC_API_KEY=

# Cohere — used by demo/graphrag_bench.py (reranker)  [REQUIRED for Cohere rerank]
COHERE_API_KEY=

# -----------------------------------------------------------------------------
# Google / Gmail Transport
# -----------------------------------------------------------------------------

# OAuth2 credentials for GmailCrawler and scripts/gmail_auth.py
# Obtain from Google Cloud Console → APIs & Services → Credentials
GOOGLE_EMAIL_CLIENT_ID=
GOOGLE_EMAIL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitHub Transport
# -----------------------------------------------------------------------------

# Personal access token for GitHubCrawler.
# Falls back to GITHUB_TOKEN; public repos work without a token (rate-limited).
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# AWS / S3 / DynamoDB
# -----------------------------------------------------------------------------

# Standard AWS credential chain — boto3 also reads ~/.aws/credentials.
# Only needed if you are not using IAM roles or instance profiles.
AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=  # set in shell, not here — never commit a secret key
AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1   # fallback if AWS_REGION is not set
# AWS_ENDPOINT_OVERRIDE=         # for LocalStack or custom S3-compatible endpoints

# -----------------------------------------------------------------------------
# Chonk MCP Server  (mcp_chonk_server.py)
# -----------------------------------------------------------------------------

# Path to the DuckDB index file (single-store mode).
# Ignored when CHONK_DB_CONFIG is set.
CHONK_DB_PATH=

# JSON map of store name → {"path": "...", "embedding_dim": N} for multi-store mode.
# Takes precedence over CHONK_DB_PATH.
# CHONK_DB_CONFIG={"default": {"path": "/data/index.duckdb", "embedding_dim": 1024}}

# Embedding dimension (default: 1024 — matches BAAI/bge-large-en-v1.5)
CHONK_EMBEDDING_DIM=1024

# Transport: stdio (default, local subprocess) or http (network server)
CHONK_TRANSPORT=stdio

# HTTP transport settings (only used when CHONK_TRANSPORT=http)
CHONK_HOST=0.0.0.0
CHONK_PORT=8000

# Bearer token for HTTP transport auth. If unset, no auth is required.
# CHONK_API_KEY=

# Together base URL (default: https://api.together.xyz/v1)
# Override for custom/dedicated deployments.
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# Chat model for the `ask` (RAG synthesis) tool (default: Qwen/Qwen3.5-9B)
CHONK_CHAT_MODEL=Qwen/Qwen3.5-9B

# Token budget passed to PromptBuilder (default: 4096)
# CHONK_ANSWER_TOKEN_BUDGET=4096

# Max tokens for LLM answer generation (default: 2048)
# CHONK_ANSWER_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# AIPA Test MCP Server  (aipa_test_mcp_server/server.py)
# -----------------------------------------------------------------------------

# LLM backend for the test server: together | ollama | anthropic (default: together)
CHONK_LLM_BACKEND=together

# Embedding model (default: BAAI/bge-large-en-v1.5)
CHONK_EMBED_MODEL=BAAI/bge-large-en-v1.5

# Ollama base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Anthropic API version (default: 2023-06-01)
# ANTHROPIC_API_VERSION=2023-06-01

# -----------------------------------------------------------------------------
# Demo / Benchmark Scripts  (demo/graphrag_bench.py, demo/compare_runs.py)
# -----------------------------------------------------------------------------

# Device for embedding model: cuda | mps | cpu (auto-detected if unset)
# EMBED_DEVICE=cpu

# Device for local reranker model (auto-detected if unset)
# RERANKER_DEVICE=cpu

# Port for the local OpenAI-compatible proxy used by demo/compare_runs.py (default: 10011)
# PROXY_PORT=10011

# -----------------------------------------------------------------------------
# canary_stamp.py (scripts/canary_stamp.py)
# -----------------------------------------------------------------------------

# Override the site-packages directory for canary injection (rarely needed)
# CANARY_SITE_DIR=
